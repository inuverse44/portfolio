---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { CATEGORIES } from '../../constants/categories';

const allPosts = await getCollection('posts', ({ data }) => data.published !== false);

const categories = CATEGORIES.map((c) => {
  const categoryPosts = allPosts.filter((p) => p.data.category === c.slug)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return { ...c, posts: categoryPosts };
});
---

<Layout title="Categories">
  <h1>Categories</h1>
  <ul style="list-style: none; padding: 0;">
    {categories.map((c) => (
      <li style="margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 1px solid #e5e5e5;">
        <h2 style="margin-top: 0;">
          <a href={`/category/${c.slug}`}>{c.title}</a>
        </h2>
        {c.description && <p style="color: #555; font-size: 0.9rem;">{c.description}</p>}
        <p style="color: #888; font-size: 0.85rem; margin: 0.25rem 0;">{c.posts.length} posts</p>
        <ul style="padding-left: 1rem; margin-top: 0.5rem;">
          {c.posts.slice(0, 3).map((p) => (
            <li><a href={`/posts/${p.slug}`}>{p.data.title}</a></li>
          ))}
        </ul>
      </li>
    ))}
  </ul>
</Layout>
