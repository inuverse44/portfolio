---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../constants/site';

const allPosts = await getCollection('posts', ({ data }) => data.published !== false);
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latestPosts = sortedPosts.slice(0, 5);
---

<Layout>
  <h1>{SITE_TITLE}</h1>
  <p>技術、科学、宇宙論、生活についてシェアします。</p>

  <hr />

  <h2>Recent Posts</h2>
  <ul style="list-style: none; padding: 0;">
    {latestPosts.map((post) => {
      const dateStr = post.data.date.toISOString().split('T')[0];
      return (
        <li style="padding: 0.4rem 0; border-bottom: 1px solid #e5e5e5;">
          <a href={`/posts/${post.slug}`}>{post.data.title}</a>
          <small style="color: #888; margin-left: 0.75rem;">{dateStr}</small>
        </li>
      );
    })}
  </ul>
  <p style="margin-top: 1rem;"><a href="/blog">すべての記事 →</a></p>
</Layout>
